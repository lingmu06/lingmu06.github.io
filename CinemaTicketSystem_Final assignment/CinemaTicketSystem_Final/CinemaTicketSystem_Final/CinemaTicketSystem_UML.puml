@startuml CinemaTicketSystem

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
skinparam ArrowColor #333333
skinparam ClassBorderColor #333333

' ============================
' ABSTRACT / MODEL CLASSES
' ============================

abstract class Person {
    - username : String
    - password : String
    --
    + Person(String, String)
    + getUsername() : String
    + getPassword() : String
    + setUsername(String) : void
    + setPassword(String) : void
    + {abstract} getRole() : String
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class Customer {
    - totalBookings : int
    --
    + Customer(String, String)
    + getTotalBookings() : int
    + incrementBookings() : void
    + getRole() : String
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class Admin {
    --
    + Admin(String, String)
    + getRole() : String
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

abstract class Seat {
    - seatId : String
    - booked : boolean
    - bookedTicketType : String
    - bookedPrice : double
    --
    + Seat(String)
    + getSeatId() : String
    + isBooked() : boolean
    + getBookedTicketType() : String
    + getBookedPrice() : double
    + book(String, double) : void
    + cancel() : void
    + {abstract} getPrice() : double
    + {abstract} getType() : String
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class StandardSeat {
    - {static} PRICE : double
    --
    + StandardSeat(String)
    + getPrice() : double
    + getType() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class VIPSeat {
    - {static} PRICE : double
    --
    + VIPSeat(String)
    + getPrice() : double
    + getType() : String
    + equals(Object) : boolean
    + hashCode() : int
}

abstract class ConcessionItem {
    - name : String
    - price : double
    - quantity : int
    --
    + ConcessionItem(String, double, int)
    + getName() : String
    + getPrice() : double
    + getQuantity() : int
    + setQuantity(int) : void
    + {abstract} getCategory() : String
    + getTotalCost() : double
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class Popcorn {
    --
    + Popcorn(String, int)
    + getCategory() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class Drink {
    --
    + Drink(String, int)
    + getCategory() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class Combo {
    --
    + Combo(String, int)
    + getCategory() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class ConcessionOrder {
    - items : ArrayList<ConcessionItem>
    - customerName : String
    --
    + ConcessionOrder(String)
    + addItem(ConcessionItem) : void
    + getItems() : ArrayList<ConcessionItem>
    + getCustomerName() : String
    + isEmpty() : boolean
    + getTotalCost() : double
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class Movie {
    - title : String
    - year : String
    - description : String
    - posterPath : String
    --
    + Movie(String, String, String)
    + Movie(String, String, String, String)
    + getTitle() : String
    + getYear() : String
    + getDescription() : String
    + getPosterPath() : String
    + setTitle(String) : void
    + setYear(String) : void
    + setDescription(String) : void
    + setPosterPath(String) : void
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

class Booking {
    - movie : String
    - seat : String
    - type : String
    - price : double
    --
    + Booking(String, String, String, double)
    + getMovie() : String
    + getSeat() : String
    + getType() : String
    + getPrice() : double
    + setMovie(String) : void
    + setSeat(String) : void
    + setType(String) : void
    + setPrice(double) : void
    + {static} calculatePrice(String) : double
    + toString() : String
    + equals(Object) : boolean
    + hashCode() : int
}

' ============================
' SERVICE CLASSES
' ============================

class SeatManager {
    - {static} BOOKING_FILE : String
    - rows : int
    - cols : int
    - seats : boolean[][]
    - prices : double[][]
    - types : String[][]
    - currentMovieFile : String
    --
    + SeatManager()
    + loadMovie(String) : void
    + bookSeat(int, int, String, double) : boolean
    + resetSeat(String, String) : void
    + isBooked(int, int) : boolean
    + getType(int, int) : String
    + getPrice(int, int) : double
    + getRows() : int
    + getCols() : int
    + getBookedCount() : int
    + getTotalPrice() : double
    + {static} saveBooking(String, String, String, double) : void
    + {static} loadAllBookings() : ArrayList<Booking>
    + {static} getBestSellingMoviesReport() : String
    + {static} getTotalRevenue() : double
}

class UserDatabase {
    - {static} FILE_NAME : String
    --
    + {static} saveUser(String, String) : void
    + {static} loadUsers() : HashMap<String,String>
    + {static} userExists(String) : boolean
}

class ConcessionItemFactory {
    --
    + {static} createPopcorn(String) : ConcessionItem
    + {static} createDrink(String) : ConcessionItem
    + {static} createCombo(String) : ConcessionItem
}

' ============================
' UI CLASSES
' ============================

class Main {
    - {static} ADMIN : Admin
    + {static} seatManager : SeatManager
    --
    + {static} main(String[]) : void
    + {static} showLoginWindow() : void
    + {static} showSignUpWindow() : void
}

class AdminDashboard <<JFrame>> {
    - seatManager : SeatManager
    --
    + AdminDashboard(SeatManager)
}

class MovieManagerFrame <<JFrame>> {
    - movieModel : DefaultListModel<String>
    - movieJList : JList<String>
    - posterPaths : ArrayList<String>
    - titleField : JTextField
    - yearField : JTextField
    - posterPathField : JTextField
    - descriptionArea : JTextArea
    - posterPreviewLabel : JLabel
    --
    + MovieManagerFrame()
    - addMovie() : void
    - editMovie() : void
    - deleteMovie() : void
    - clearFields() : void
    - saveAllToFile() : void
    - loadMoviesFromFile() : void
}

class CustomerMenu <<JFrame>> {
    - seatManager : SeatManager
    - currentUsername : String
    - posterMap : HashMap<String,String>
    - posterLabel : JLabel
    --
    + CustomerMenu(SeatManager, String)
    - loadMovies(DefaultListModel) : void
    - updatePosterDisplay(String) : void
}

class SeatSelectionFrame <<JFrame>> {
    --
    + SeatSelectionFrame(SeatManager, String, String)
}

class ConcessionFrame <<JFrame>> {
    --
    + ConcessionFrame(String, double, ArrayList, String)
}

class ReceiptFrame {
    --
    + {static} show(String, double, ArrayList, ArrayList, String, String) : void
}

class SnackOrderFrame <<JFrame>> {
    --
    + SnackOrderFrame()
}

class ViewBookingFrame <<JFrame>> {
    - seatManager : SeatManager
    - bookingModel : DefaultListModel<Booking>
    - bookingList : JList<Booking>
    - totalLabel : JLabel
    --
    + ViewBookingFrame(SeatManager)
    - loadBookings() : void
    - deleteSelected() : void
    - deleteAll() : void
    - saveAll() : void
    - updateTotalLabel() : void
}

' ============================
' RELATIONSHIPS
' ============================

' Inheritance
Person      <|-- Customer
Person      <|-- Admin
Seat        <|-- StandardSeat
Seat        <|-- VIPSeat
ConcessionItem <|-- Popcorn
ConcessionItem <|-- Drink
ConcessionItem <|-- Combo

' Composition (SeatManager owns Seat objects)
SeatManager *--> Seat

' Aggregation (ConcessionOrder has ConcessionItems)
ConcessionOrder o--> ConcessionItem

' Associations
Main --> SeatManager
Main --> AdminDashboard
Main --> CustomerMenu

AdminDashboard --> SeatManager
AdminDashboard --> MovieManagerFrame
AdminDashboard --> ViewBookingFrame
AdminDashboard --> SnackOrderFrame

CustomerMenu --> SeatManager
CustomerMenu --> SeatSelectionFrame

SeatSelectionFrame --> SeatManager
SeatSelectionFrame --> ConcessionFrame
SeatSelectionFrame --> ReceiptFrame

ConcessionFrame --> ConcessionOrder
ConcessionFrame --> ConcessionItemFactory
ConcessionFrame --> ReceiptFrame

ConcessionItemFactory --> Popcorn
ConcessionItemFactory --> Drink
ConcessionItemFactory --> Combo

' Dependencies (uses temporarily)
SeatManager     ..> Booking
ViewBookingFrame ..> Booking
ReceiptFrame    ..> ConcessionItem

@enduml
